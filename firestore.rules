rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if document belongs to current user
    function belongsToUser() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Helper function to check if new document will belong to current user
    function willBelongToUser() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    // Borrowers collection - users can only access their own borrowers
    match /borrowers/{borrowerId} {
      // Read: only if document belongs to current user
      allow read: if belongsToUser();
      
      // Create: only if userId matches current user
      allow create: if willBelongToUser();
      
      // Update/Delete: only if document belongs to current user
      allow update, delete: if belongsToUser();
    }
    
    // Collections (payment records) - users can only access their own
    match /collections/{collectionId} {
      allow read: if belongsToUser();
      allow create: if willBelongToUser();
      allow update, delete: if belongsToUser();
    }
    
    // Payment slots/schedule - users can only access their own
    match /payments/{paymentId} {
      allow read: if belongsToUser();
      allow create: if willBelongToUser();
      allow update, delete: if belongsToUser();
    }
    
    // Users collection - users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Reminders collection - users can only access their own reminders
    match /reminders/{reminderId} {
      allow read: if belongsToUser();
      allow create: if willBelongToUser();
      allow update, delete: if belongsToUser();
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
